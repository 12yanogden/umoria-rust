{
  "name": "umoria-web",
  "version": "0.1.0",
  "private": true,
  "description": "Umoria documentation site (Astro + Entropic textmode theme).",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "bun run check && astro build",
    "preview": "astro preview",
    "check": "astro check && biome check .",
    "test:nav": "node --test scripts/check-nav-chrome.mjs",
    "test:footer": "node --test scripts/check-footer-chrome.mjs",
    "test:home": "node --test scripts/check-home-hero.mjs",
    "test:downloads": "node --test scripts/check-downloads-page.mjs",
    "test:deploy-workflow": "node --test scripts/check-deploy-workflow.mjs",
    "test:pages": "node --test scripts/check-pages-alignment.mjs",
    "test:pages-docs": "node --test scripts/check-pages-docs.mjs",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "docs:generate-stubs": "node --experimental-strip-types scripts/generate-docs-stubs.ts",
    "test": "node --experimental-strip-types --test src/content/docs-nav.test.ts src/content/docs-catalog.test.ts src/content/docs-stubs.test.ts src/content/docs-index.test.ts src/content/docs-sidebar.test.ts src/content/catalog-fragments/getting-started.test.ts src/content/catalog-fragments/__tests__/character.test.ts src/content/catalog-fragments/__tests__/dungeon-combat.test.ts src/content/catalog-fragments/items.test.ts src/content/catalog-fragments/spells-wizard-reference.test.ts src/modules/philes/schema.test.ts src/modules/philes/sources.test.ts",
    "test:catalog": "node --experimental-strip-types --test src/content/docs-catalog.test.ts",
    "test:docs-stubs": "node --experimental-strip-types --test src/content/docs-stubs.test.ts",
    "test:docs-index": "node --experimental-strip-types --test src/content/docs-index.test.ts",
    "test:docs-sidebar": "node --experimental-strip-types --test src/content/docs-sidebar.test.ts",
    "assets:fonts": "bun run fonts:subset && bun run fonts:atlas",
    "fonts:atlas": "node scripts/build-cjk-atlas.mjs",
    "fonts:subset": "node scripts/subset-fonts.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@chenglou/pretext": "^0.0.7",
    "astro": "^7.0.0",
    "typescript": "^5.8.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0"
  },
  "overrides": {
    "yaml": "2.9.0"
  }
}
